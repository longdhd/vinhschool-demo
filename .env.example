# Public Google Calendar embed URL.
# Google Calendar -> Settings -> Integrate calendar -> Embed code.
# Copy only the iframe src URL, not the whole iframe tag.
NEXT_PUBLIC_GOOGLE_CALENDAR_EMBED_URL="https://calendar.google.com/calendar/embed?src=b40f27e1f5ca53f9a2dec6bc45599f898a1c13741fd02ed915e213953adddf05@group.calendar.google.com&ctz=America%2FLos_Angeles"

# Server-only Google Calendar iCal URL used to infer the latest event update.
# Google Calendar -> Settings -> Integrate calendar.
# Use either "Public address in iCal format" or "Secret address in iCal format".
# Keep this server-only. Do not prefix with NEXT_PUBLIC_.
GOOGLE_CALENDAR_ICS_URL="https://calendar.google.com/calendar/ical/b40f27e1f5ca53f9a2dec6bc45599f898a1c13741fd02ed915e213953adddf05%40group.calendar.google.com/private-b1ed8ee0119bfe329619eeb439ceac40/basic.ics"

# Server-only contact form email delivery using Resend.
# Add these in Vercel Project Settings -> Environment Variables.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
CONTACT_TO_EMAIL="your-inbox@example.com"
CONTACT_FROM_EMAIL="VinhSchool <contact@yourdomain.com>"
